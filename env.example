# ============================================
# ENVIRONMENT VARIABLES - JOEL'S PORTFOLIO
# ============================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to: .env
# 2. Fill in your actual values below
# 3. NEVER commit your .env file to GitHub!
# ============================================

# Your PostgreSQL database URL from Render.com
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://joel:yourpassword@localhost:5432/portfolio_db

# Set to "production" when deployed on Render
NODE_ENV=development

# Port (Render sets this automatically, leave as 3000 for local)
PORT=3000
